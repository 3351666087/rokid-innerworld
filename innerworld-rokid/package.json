{
  "name": "innerworld-rokid",
  "version": "0.1.0",
  "private": true,
  "description": "Rokid InnerWorld campus memory wall localhost prototype.",
  "type": "module",
  "scripts": {
    "dev": "node server/space-server/index.js",
    "dev:lan": "powershell -NoProfile -ExecutionPolicy Bypass -File start-lan.ps1",
    "start": "node server/space-server/index.js",
    "check": "node server/space-server/check.js",
    "check:mainline": "node server/space-server/check-mainline.js",
    "check:contract": "node server/space-server/check-contract.js --require-unity",
    "check:device": "node server/space-server/check-device.js",
    "check:device-probe": "node server/space-server/check-device-probe.js",
    "check:station-apk": "node server/space-server/check-station-pro-apk-smoke.js",
    "check:station-apk:lan": "node server/space-server/check-station-pro-apk-smoke.js --require-lan",
    "check:station-apk:rkimage": "node server/space-server/check-station-pro-apk-smoke.js --skip-smoke --require-lan --require-rkimage-db --require-rokid-native-libs",
    "check:station-glasses": "node server/space-server/check-station-pro-glasses-diagnostics.js",
    "check:station-glasses:ready": "node server/space-server/check-station-pro-glasses-diagnostics.js --require-ready",
    "check:uxr-readiness": "node server/space-server/check-uxr-readiness.js",
    "check:uxr-readiness:ready": "node server/space-server/check-uxr-readiness.js --require-ready",
    "check:store": "node server/space-server/check-store.js",
    "check:service-actions": "node server/space-server/check-service-actions.js",
    "check:security": "node server/space-server/check-security.js",
    "check:readonly": "node server/space-server/check-readonly.js",
    "check:ops": "node server/space-server/check-ops.js",
    "check:field-markers": "node server/space-server/check-field-markers.js",
    "check:field-acceptance": "node server/space-server/check-field-acceptance.js",
    "check:field-live-pass": "node tools/field-live-pass.js --single --require-live-session",
    "check:field-target-pass": "node tools/field-target-pass.js --require-live-session",
    "check:field-operator-plan": "node server/space-server/check-field-operator-plan.js",
    "check:web": "node server/space-server/check-web-demo.js",
    "check:unity": "node server/space-server/check-unity.js",
    "context:export": "node tools/export-context.js",
    "device:probe": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/device-probe.ps1",
    "device:probe:strict": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/device-probe.ps1 -RequireAdbDevice",
    "station:apk:inspect": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/station-pro-apk-smoke.ps1",
    "station:apk:patch-lan": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/patch-apk-config.ps1",
    "station:apk:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/station-pro-apk-smoke.ps1 -RequireDevice -InstallAndLaunch",
    "station:apk:display-smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/station-pro-apk-smoke.ps1 -RequireDevice -InstallAndLaunch -RequireGlassesDisplay",
    "station:apk:pair-smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/station-pro-apk-smoke.ps1 -RequireDevice -InstallAndLaunch -PairWithOperator",
    "station:glasses:diagnose": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/station-pro-glasses-diagnostics.ps1",
    "station:glasses:require-ready": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/station-pro-glasses-diagnostics.ps1 -RequireReady",
    "env:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/env-doctor.ps1",
    "evidence:rehearsal": "node server/space-server/capture-rehearsal.js",
    "field:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/field-preflight.ps1",
    "field:operator-plan": "node tools/field-operator-plan.js",
    "field:live-pass": "node tools/field-live-pass.js",
    "field:live-pass:watch": "node tools/field-live-pass.js --duration-sec 120 --interval-sec 2 --logcat",
    "field:target-pass": "node tools/field-target-pass.js",
    "field:target-pass:watch": "node tools/field-target-pass.js --watch --require-live-session --require-target-diagnostics",
    "field:target-pass:apply": "node tools/field-target-pass.js --apply-mission-actions --require-live-session --require-target-diagnostics",
    "field:target-pass:strict": "node tools/field-target-pass.js --apply-mission-actions --confirm-user-b-readback --require-live-session --require-target-diagnostics --require-trusted --require-mission-loop",
    "field:acceptance-session": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/field-acceptance-session.ps1",
    "field:acceptance-session:live": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/field-acceptance-session.ps1 -PairSmoke -Watch",
    "field:acceptance-session:strict": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/field-acceptance-session.ps1 -PairSmoke -Watch -RequireTrusted -RequireMissionLoop",
    "field:acceptance-session:target": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/field-acceptance-session.ps1 -PairSmoke -Watch -TargetPass",
    "field:acceptance-session:target-strict": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/field-acceptance-session.ps1 -PairSmoke -Watch -TargetPass -ApplyMissionActions -ConfirmUserBReadback -RequireTrusted -RequireMissionLoop",
    "pdf:fieldkit": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/render-field-kit-pdf.ps1",
    "release:index": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/release-index.ps1",
    "reset": "node server/space-server/reset.js",
    "server:package": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/package-server-release.ps1",
    "server:deploy-plan": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/server-deploy-plan.ps1",
    "server:deploy-dry-run": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/deploy-dry-run-server.ps1",
    "server:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/smoke-server-release.ps1",
    "package:demo": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/package-demo.ps1",
    "package:demo:noclean": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/package-demo.ps1 -SkipCacheClean",
    "package:audit": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/audit-demo-package.ps1",
    "verify:release": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/verify-release.ps1",
    "ops:monitor": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/ops-monitor.ps1",
    "ops:monitor:once": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/ops-monitor.ps1 -RunOnce",
    "ops:monitor:clean:once": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/ops-monitor.ps1 -RunOnce -ApplySafeCleanup -CleanupEveryIterations 1",
    "ops:monitor:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/ops-monitor.ps1 -ApplySafeCleanup -CleanupEveryIterations 1",
    "ops:monitor:status": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/ops-monitor-status.ps1",
    "cache:report": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/cache-clean.ps1",
    "cache:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/cache-clean.ps1 -Apply",
    "cache:temp:report": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/temp-clean.ps1",
    "cache:temp:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/temp-clean.ps1 -Apply",
    "db:backup": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/sqlite-backup.ps1",
    "db:backup:list": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/sqlite-backup.ps1 -List",
    "db:backup:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/sqlite-backup.ps1 -VerifyLatest",
    "git:sync": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/git-auto-sync.ps1 -IncludeUntracked",
    "git:sync:dry": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/git-auto-sync.ps1 -DryRun -IncludeUntracked",
    "git:sync:loop": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/git-auto-sync.ps1 -Loop -IntervalSeconds 300 -IncludeUntracked",
    "unity:config": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/set-unity-config.ps1",
    "rokid:image-db": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/build-rokid-image-db.ps1",
    "unity:android:build": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/build-unity-android.ps1",
    "unity:android:build:lan": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/build-unity-android.ps1 -RunPostChecks -RequirePostCheckDevice",
    "uxr:doctor": "node tools/uxr-readiness.js",
    "unity:android:install": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/install-unity-android.ps1"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
